{
    "name": "vitalytics/laravel-sdk",
    "description": "Vitalytics SDK for Laravel - Health monitoring, analytics tracking, user feedback collection, and database health monitoring",
    "version": "1.4.0",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/RyanG2016/vitalytics-laravel-sdk",
    "keywords": ["laravel", "monitoring", "analytics", "crash-reporting", "health", "vitalytics"],
    "authors": [
        {
            "name": "Vitalytics",
            "email": "support@vitalytics.app"
        }
    ],
    "support": {
        "issues": "https://github.com/RyanG2016/vitalytics-laravel-sdk/issues",
        "source": "https://github.com/RyanG2016/vitalytics-laravel-sdk"
    },
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Vitalytics\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Vitalytics\\VitalyticsServiceProvider"
            ],
            "aliases": {
                "Vitalytics": "Vitalytics\\Facades\\Vitalytics",
                "VitalyticsAnalytics": "Vitalytics\\Facades\\VitalyticsAnalytics"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
